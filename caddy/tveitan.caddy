# Caddy site snippet. Drop it into the proxy's config dir and reload Caddy;
# it auto-provisions TLS once DNS for tveitan.se points at the host.
# (Install path / reload command are environment-specific — see local notes.)
tveitan.se, www.tveitan.se {
    encode gzip zstd
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }
    reverse_proxy tveitan:8080
}
