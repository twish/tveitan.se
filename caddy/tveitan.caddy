# Install on the VPS at /opt/caddy/config/tveitan.caddy then reload:
#   docker exec caddy-caddy-1 caddy reload --config /etc/caddy/Caddyfile
# Caddy auto-provisions TLS once DNS for tveitan.se points at the VPS.
tveitan.se, www.tveitan.se {
    encode gzip zstd
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }
    reverse_proxy tveitan:8080
}
